DATABASE_URL=postgresql://wholo:wholo@localhost:5432/wholo
JWT_SECRET=dev-secret-change-in-prod
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
REDIS_URL=redis://localhost:6379
PORT=3001
NODE_ENV=development

# Cloudflare R2 object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Email (defaults target MailHog; port-forward it for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=noreply@wholo.com.au

# Externally reachable admin app URL — used in email links (worker process)
ADMIN_URL=http://localhost:3020
