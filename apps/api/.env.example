DATABASE_URL=postgresql://wholo:wholo@localhost:5432/wholo
JWT_SECRET=dev-secret-change-in-prod
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
REDIS_URL=redis://localhost:6379
PORT=3001
NODE_ENV=development

# Cloudflare R2 object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Email (defaults target MailHog; port-forward it for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=noreply@wholo.com.au
# From address for invite emails specifically; falls back to SMTP_FROM if unset.
SMTP_INVITE_FROM=

# Externally reachable admin app URL — used in email links (worker process)
ADMIN_URL=http://localhost:3020

# Xero accounting integration
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# This is apps/admin-api's public callback URL (the admin app's own origin),
# not a route on this service — see xero-connection.adapter.ts for why.
# Xero requires HTTPS even for local testing — see scripts/setup-local-xero-https.sh
# (routes admin.localhost through the local Traefik ingress; requires
# `kubectl port-forward svc/traefik -n traefik 8443:443` while testing).
XERO_REDIRECT_URI=https://admin.localhost:8443/api/v1/accounting/xero/callback
ACCOUNTING_TOKEN_ENCRYPTION_KEY=
