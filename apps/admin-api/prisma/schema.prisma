generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

enum OrganisationType {
  DISTRIBUTOR
  TRADE_CUSTOMER
}

enum Role {
  PLATFORM_ADMIN
  DISTRIBUTOR_ADMIN
  WAREHOUSE_STAFF
  DRIVER
  TRADE_CUSTOMER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum TradeRelationshipStatus {
  PENDING_INVITE
  PENDING_REQUEST
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// Cart backing data — temporary, cleared on submission
enum CartOrderStatus {
  DRAFT
}

// Commercial order statuses
enum OrderStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum OrderLineStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
  CANCELLED
}

enum OrderAcceptanceMode {
  MANUAL
  AUTO_ON_SUBMISSION
}

enum AcceptanceModeSource {
  DISTRIBUTOR_DEFAULT
  TRADER_CUSTOMER_OVERRIDE
}

enum AcceptedByActorType {
  USER
  SYSTEM
}

enum OutboxEventStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum NotificationType {
  ORDER_PLACED
}

enum NotificationChannel {
  EMAIL
  WEB_PUSH
  IN_APP
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationAudience {
  DISTRIBUTOR
  CUSTOMER
}

enum PriceListRuleSelectorType {
  ALL_PRODUCTS
  PRODUCT
}

enum PriceListRuleValueType {
  FIXED_PRICE
  PERCENTAGE_DISCOUNT
}

enum PriceListRuleDiscountBaseType {
  PRODUCT_PRICE
  PRICE_LIST
}

enum AccountingProvider {
  XERO
}

enum AccountingConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  REVOKED
}

enum AccountingContactMatchStatus {
  SUGGESTED
  ACCEPTED
  REJECTED
  SUPERSEDED
}

enum AccountingContactMatchMethod {
  ACCOUNT_CODE_EXACT
  EMAIL_EXACT
  NAME_EXACT
  NAME_POSTCODE
  NAME_FUZZY
  MANUAL
}

enum AccountingProductMatchStatus {
  SUGGESTED
  ACCEPTED
  REJECTED
  SUPERSEDED
}

enum AccountingProductMatchMethod {
  SKU_EXACT
  SKU_NORMALISED
  NAME_EXACT
  NAME_FUZZY
  MANUAL
}

model Organisation {
  id                              String              @id @default(cuid())
  name                            String
  slug                            String?             @unique
  type                            OrganisationType
  email                           String?
  phone                           String?
  legalName                       String?
  addressLine1                    String?
  addressLine2                    String?
  addressCity                     String?
  addressState                    String?
  addressPostcode                 String?
  addressCountry                  String?
  billingLine1                    String?
  billingLine2                    String?
  billingCity                     String?
  billingState                    String?
  billingPostcode                 String?
  billingCountry                  String?
  createdAt                       DateTime            @default(now())
  updatedAt                       DateTime            @updatedAt
  deletedAt                       DateTime?
  memberships                     Membership[]
  productTypes                    ProductType[]       @relation("DistributorProductTypes")
  suppliers                       Supplier[]          @relation("DistributorSuppliers")
  products                        Product[]           @relation("DistributorProducts")
  catalogues                      Catalogue[]         @relation("DistributorCatalogues")
  tradeRelationshipsAsDistributor TradeRelationship[] @relation("DistributorRelationships")
  tradeRelationshipsAsCustomer    TradeRelationship[] @relation("CustomerRelationships")
  customerInvitations             CustomerInvitation[]
  cartOrdersAsDistributor         CartOrder[]         @relation("DistributorCartOrders")
  cartOrdersAsCustomer            CartOrder[]         @relation("CustomerCartOrders")
  ordersAsDistributor             Order[]             @relation("DistributorOrders")
  ordersAsCustomer                Order[]             @relation("CustomerOrders")
  distributorSettings             DistributorSettings?
  priceLists                      PriceList[]         @relation("DistributorPriceLists")
  deliveryProfiles                DeliveryProfile[]   @relation("DistributorDeliveryProfiles")
  orderAsSessionsAsDistributor    OrderAsSession[]    @relation("OrderAsDistributor")
  orderAsSessionsAsCustomer       OrderAsSession[]    @relation("OrderAsCustomer")
  accountingConnections           AccountingConnection[]
  externalAccountingContacts      ExternalAccountingContact[]
  customerAccountingMappings      CustomerAccountingMapping[]
  accountingContactMatchSuggestions AccountingContactMatchSuggestion[]
  externalAccountingProducts      ExternalAccountingProduct[]
  productAccountingMappings       ProductAccountingMapping[]
  accountingProductMatchSuggestions AccountingProductMatchSuggestion[]

  @@map("organisations")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  keycloakId    String?        @unique
  passwordHash  String?
  firstName     String
  lastName      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  memberships   Membership[]
  refreshTokens RefreshToken[]
  cartOrders    CartOrder[]
  orderAsSessions      OrderAsSession[]      @relation("AdminOrderAsSessions")
  delegateOrders       Order[]               @relation("DelegateOrders")

  @@map("users")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organisationId String
  role           Role
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id])
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  @@unique([userId, organisationId])
  @@map("memberships")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model ProductType {
  id            String       @id @default(cuid())
  distributorId String
  name          String
  code          String
  displayOrder  Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  distributor   Organisation @relation("DistributorProductTypes", fields: [distributorId], references: [id])
  products      Product[]

  @@unique([distributorId, code])
  @@index([distributorId])
  @@map("product_types")
}

model Supplier {
  id            String       @id @default(cuid())
  distributorId String
  name          String
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  distributor   Organisation @relation("DistributorSuppliers", fields: [distributorId], references: [id])
  products      Product[]

  @@index([distributorId])
  @@map("suppliers")
}

model Product {
  id                 String                     @id @default(cuid())
  distributorId      String
  productTypeId      String?
  supplierId         String?
  name               String
  description        String?
  sku                String?
  status             ProductStatus              @default(DRAFT)
  price              Decimal?                   @db.Decimal(10, 2)
  compareAtPrice     Decimal?                   @db.Decimal(10, 2)
  deletedAt          DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  distributor        Organisation               @relation("DistributorProducts", fields: [distributorId], references: [id])
  productType        ProductType?               @relation(fields: [productTypeId], references: [id])
  supplier           Supplier?                  @relation(fields: [supplierId], references: [id])
  externalReferences ProductExternalReference[]
  cartOrderLines     CartOrderLine[]
  orderLines         OrderLine[]
  catalogues         CatalogueProduct[]
  priceListRules     PriceListRule[]             @relation("ProductPriceListRules")
  searchDocument     ProductSearchDocument?
  accountingMappings ProductAccountingMapping[]
  accountingMatchSuggestions AccountingProductMatchSuggestion[]

  @@unique([distributorId, sku])
  @@index([distributorId, createdAt])
  @@index([distributorId, deletedAt])
  @@map("products")
}

// Curated search document per product (see ADR-050). App code maintains the
// text fields; searchVector is a Postgres generated column derived from
// searchText (added in the migration — Prisma cannot express generated columns).
model ProductSearchDocument {
  productId            String                   @id
  distributorId        String
  searchText           String
  searchTextNormalised String
  nameNormalised       String
  skuNormalised        String?
  searchVector         Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, \"searchText\")"))
  updatedAt            DateTime                 @updatedAt
  product              Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([distributorId])
  @@index([searchVector], type: Gin)
  @@index([searchTextNormalised(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([nameNormalised(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([skuNormalised(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("product_search_documents")
}

// Superseded for accounting by ProductAccountingMapping (connection-scoped,
// soft-unlink, matchMethod audit trail). Kept for a future non-accounting
// external-id use case; nothing reads or writes it today.
model ProductExternalReference {
  id            String   @id @default(cuid())
  productId     String
  distributorId String
  source        String
  externalId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       Product  @relation(fields: [productId], references: [id])

  @@unique([productId, source])
  @@index([distributorId, source])
  @@map("product_external_references")
}

model TradeRelationship {
  id               String                  @id @default(cuid())
  distributorId    String
  customerId       String
  status           TradeRelationshipStatus @default(PENDING_INVITE)
  accountNumber    String?
  creditLimit          Decimal?                @db.Decimal(10, 2)
  minimumOrderSpend    Decimal?                @db.Decimal(10, 2)
  paymentTerms         String?
  notes            String?
  deliveryLine1    String?
  deliveryLine2    String?
  deliveryCity     String?
  deliveryState    String?
  deliveryPostcode String?
  deliveryCountry  String?
  deletedAt        DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  distributor      Organisation            @relation("DistributorRelationships", fields: [distributorId], references: [id])
  customer         Organisation            @relation("CustomerRelationships", fields: [customerId], references: [id])
  invitations      CustomerInvitation[]
  catalogues       CustomerCatalogue[]
  traderCustomerSettings TraderCustomerSettings?
  orderAsSessions        OrderAsSession[]
  accountingMappings     CustomerAccountingMapping[]
  accountingMatchSuggestions AccountingContactMatchSuggestion[]

  @@unique([distributorId, customerId])
  @@index([distributorId, createdAt])
  @@index([distributorId, status])
  @@index([customerId, status])
  @@map("trade_relationships")
}

model CustomerInvitation {
  id                  String            @id @default(cuid())
  tradeRelationshipId String
  distributorId       String
  email               String
  token               String            @unique
  status              InvitationStatus  @default(PENDING)
  expiresAt           DateTime
  acceptedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tradeRelationship   TradeRelationship @relation(fields: [tradeRelationshipId], references: [id])
  distributor         Organisation      @relation(fields: [distributorId], references: [id])

  @@index([token])
  @@index([distributorId])
  @@map("customer_invitations")
}

// ─── Cart backing data ────────────────────────────────────────────────────────

model CartOrder {
  id            String          @id @default(cuid())
  distributorId String
  customerId    String
  userId        String
  status        CartOrderStatus @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  distributor   Organisation    @relation("DistributorCartOrders", fields: [distributorId], references: [id])
  customer      Organisation    @relation("CustomerCartOrders", fields: [customerId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
  lines         CartOrderLine[]

  @@unique([distributorId, customerId, userId, status])
  @@index([distributorId, status])
  @@index([customerId, status])
  @@map("cart_orders")
}

model CartOrderLine {
  id                      String    @id @default(cuid())
  orderId                 String
  productId               String
  quantity                Int
  unitPrice               Decimal   @db.Decimal(10, 2)
  resolvedPriceListId     String?
  resolvedPriceListRuleId String?
  priceResolvedAt         DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  order                   CartOrder @relation(fields: [orderId], references: [id])
  product                 Product   @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
  @@map("cart_order_lines")
}

// ─── Commercial orders ────────────────────────────────────────────────────────

model Order {
  id               String               @id @default(cuid())
  distributorId    String
  traderCustomerId String
  placedByUserId   String
  orderNumber      String               @unique

  status                       OrderStatus
  fulfilmentStatus             String?
  invoiceStatus                String?
  paymentStatus                String?

  acceptanceModeSnapshot       OrderAcceptanceMode
  acceptanceModeSourceSnapshot AcceptanceModeSource

  currency       String              @default("GBP")
  subtotalAmount Decimal             @db.Decimal(10, 2)
  taxAmount      Decimal             @db.Decimal(10, 2)
  totalAmount    Decimal             @db.Decimal(10, 2)

  billingAddressSnapshot  Json?
  deliveryAddressSnapshot Json?
  requestedDeliveryDate   DateTime? @db.Date
  customerReference       String?
  notes                   String?

  submittedAt          DateTime?
  acceptedAt           DateTime?
  acceptedByActorType  AcceptedByActorType?
  acceptedByUserId     String?
  rejectedAt           DateTime?
  rejectedByUserId     String?
  rejectionReason      String?
  cancelledAt          DateTime?
  cancelledByUserId    String?
  cancellationReason   String?

  isOrderedByDelegate   Boolean  @default(false)
  delegateAdminUserId   String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  distributor    Organisation @relation("DistributorOrders", fields: [distributorId], references: [id])
  customer       Organisation @relation("CustomerOrders", fields: [traderCustomerId], references: [id])
  delegateAdmin  User?        @relation("DelegateOrders", fields: [delegateAdminUserId], references: [id])
  lines          OrderLine[]
  notifications  Notification[]

  @@index([distributorId, status])
  @@index([traderCustomerId, status])
  @@index([distributorId, createdAt])
  @@map("orders")
}

model OrderLine {
  id               String          @id @default(cuid())
  orderId          String
  distributorId    String
  traderCustomerId String
  productId        String

  productVariantId       String?
  skuSnapshot            String?
  productNameSnapshot    String
  unitOfMeasureSnapshot  String?

  quantityOrdered         Int
  unitPriceSnapshot       Decimal @db.Decimal(10, 2)
  taxRateSnapshot         String  @default("0")
  subtotalAmount          Decimal @db.Decimal(10, 2)
  taxAmount               Decimal @db.Decimal(10, 2)
  totalAmount             Decimal @db.Decimal(10, 2)
  priceListIdSnapshot     String?
  priceListRuleIdSnapshot String?

  status    OrderLineStatus
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([distributorId])
  @@map("order_lines")
}

// ─── Acceptance configuration ─────────────────────────────────────────────────

model DistributorSettings {
  distributorId              String              @id
  defaultOrderAcceptanceMode OrderAcceptanceMode @default(MANUAL)
  marketplaceVisible         Boolean             @default(false)
  marketplaceDescription     String?
  tagline                    String?
  aboutText                  String?
  orderNotificationEmails    String[]            @default([])
  processingDays             Int[]               @default([1, 2, 3, 4, 5])
  minimumOrderSpend          Decimal?            @db.Decimal(10, 2)
  distributor                Organisation        @relation(fields: [distributorId], references: [id])

  @@map("distributor_settings")
}

// ─── Accounting integration ───────────────────────────────────────────────────
// Provider-neutral: Xero is the first AccountingProvider, not the shape of the
// model. Historical rows are kept (never deleted) when a distributor
// disconnects/reconnects — "one active connection per distributor" is enforced
// by a partial unique index added by hand in the generated migration (Prisma's
// schema DSL cannot express a WHERE clause on a unique index).
model AccountingConnection {
  id                       String                     @id @default(cuid())
  distributorId            String
  provider                 AccountingProvider
  status                   AccountingConnectionStatus
  externalOrganisationId   String
  externalOrganisationName String
  scopes                   String
  encryptedCredentialData  String
  connectedByUserId        String
  connectedAt              DateTime
  disconnectedAt           DateTime?
  lastSyncedAt             DateTime?
  lastErrorAt              DateTime?
  lastErrorMessage         String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  distributor              Organisation               @relation(fields: [distributorId], references: [id])
  externalContacts         ExternalAccountingContact[]
  customerMappings         CustomerAccountingMapping[]
  contactMatchSuggestions  AccountingContactMatchSuggestion[]
  externalProducts         ExternalAccountingProduct[]
  productMappings          ProductAccountingMapping[]
  productMatchSuggestions  AccountingProductMatchSuggestion[]

  @@index([distributorId])
  @@map("accounting_connections")
}

// Short-lived, single-use CSRF/correlation row for the OAuth connect flow.
// Xero's callback redirect carries only code+state, no Wholo JWT, so this row
// (not a guard) is what proves the callback belongs to a given distributor.
model AccountingOAuthState {
  id                String             @id @default(cuid())
  state             String             @unique
  provider          AccountingProvider
  distributorId     String
  connectedByUserId String
  createdAt         DateTime           @default(now())
  expiresAt         DateTime

  @@map("accounting_oauth_states")
}

// Locally cached contacts pulled from the connected accounting system (Xero
// initially). Populated only through AccountingConnectionAdapter.listContacts
// — "provider" plus generic field names keep a second provider a pure
// adapter addition, nothing here is Xero-specific.
model ExternalAccountingContact {
  id                     String             @id @default(cuid())
  distributorId          String
  accountingConnectionId String
  provider               AccountingProvider
  externalContactId      String
  externalContactCode    String?
  externalAccountNumber  String?
  displayName            String
  email                  String?
  billingLine1           String?
  billingLine2           String?
  billingCity            String?
  billingState           String?
  billingPostcode        String?
  billingCountry         String?
  isCustomer             Boolean            @default(false)
  isSupplier             Boolean            @default(false)
  isArchived             Boolean            @default(false)
  ignoredAt              DateTime?
  lastExternalUpdatedAt  DateTime?
  lastSyncedAt           DateTime
  rawProviderData        Json
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  distributor Organisation                       @relation(fields: [distributorId], references: [id])
  connection  AccountingConnection               @relation(fields: [accountingConnectionId], references: [id])
  // One-to-many, not one-to-one: unlinking soft-deletes (unlinkedAt) rather
  // than hard-deleting, so a contact can accumulate historical mapping rows
  // even though only one is ever active (unlinkedAt IS NULL) at a time.
  mappings    CustomerAccountingMapping[]
  suggestions AccountingContactMatchSuggestion[]

  @@unique([accountingConnectionId, externalContactId])
  @@index([distributorId, isCustomer, isArchived])
  @@map("external_accounting_contacts")
}

// Confirmed link between a Wholo customer (TradeRelationship, in the context
// of one distributor) and one cached external contact. Written only by an
// explicit user action (import/confirm/match) — never by the sync/matcher,
// regardless of match confidence.
model CustomerAccountingMapping {
  id                     String                        @id @default(cuid())
  distributorId          String
  accountingConnectionId String
  tradeRelationshipId    String
  externalContactId      String
  matchMethod            AccountingContactMatchMethod
  linkedByUserId         String
  linkedAt               DateTime                      @default(now())
  unlinkedAt             DateTime?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt

  distributor       Organisation              @relation(fields: [distributorId], references: [id])
  connection         AccountingConnection      @relation(fields: [accountingConnectionId], references: [id])
  tradeRelationship TradeRelationship          @relation(fields: [tradeRelationshipId], references: [id])
  externalContact    ExternalAccountingContact @relation(fields: [externalContactId], references: [id])

  // Both uniques below are made partial (WHERE "unlinkedAt" IS NULL) by hand
  // in the generated migration — same precedent as
  // unique_active_accounting_connection above. An unlink-then-relink of the
  // same pair must not collide with the closed-out row.
  @@unique([accountingConnectionId, tradeRelationshipId])
  @@unique([accountingConnectionId, externalContactId])
  @@index([distributorId])
  @@map("customer_accounting_mappings")
}

// System-suggested match awaiting human review. The matcher only ever writes
// here; CustomerAccountingMapping rows are created exclusively by an
// explicit confirm/match action, regardless of confidence.
model AccountingContactMatchSuggestion {
  id                            String                        @id @default(cuid())
  distributorId                 String
  accountingConnectionId        String
  externalContactId             String
  suggestedTradeRelationshipId  String
  confidence                    Int
  matchMethod                   AccountingContactMatchMethod
  matchReason                   String
  status                        AccountingContactMatchStatus @default(SUGGESTED)
  reviewedByUserId              String?
  reviewedAt                    DateTime?
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt

  distributor                Organisation              @relation(fields: [distributorId], references: [id])
  connection                  AccountingConnection      @relation(fields: [accountingConnectionId], references: [id])
  externalContact             ExternalAccountingContact @relation(fields: [externalContactId], references: [id])
  suggestedTradeRelationship TradeRelationship          @relation(fields: [suggestedTradeRelationshipId], references: [id])

  @@index([distributorId, status])
  @@index([externalContactId, status])
  @@map("accounting_contact_match_suggestions")
}

// Locally cached products/items pulled from the connected accounting system
// (Xero Items initially). Populated only through
// AccountingConnectionAdapter.listProducts — same provider-neutral cache
// pattern as ExternalAccountingContact. Prices are Decimal(12,4): Xero
// serves 4-dp unit prices (unitdp=4); rounding to Wholo's 2-dp Product.price
// happens only at import, never in the cache.
model ExternalAccountingProduct {
  id                     String             @id @default(cuid())
  distributorId          String
  accountingConnectionId String
  provider               AccountingProvider
  externalProductId      String
  externalProductCode    String?
  displayName            String
  description            String?
  salesUnitPrice         Decimal?           @db.Decimal(12, 4)
  purchaseUnitPrice      Decimal?           @db.Decimal(12, 4)
  taxCode                String?
  accountCode            String?
  purchaseTaxCode        String?
  purchaseAccountCode    String?
  isSold                 Boolean            @default(true)
  isPurchased            Boolean            @default(true)
  isTracked              Boolean            @default(false)
  // Xero Items have no archived flag — deleted items simply vanish from the
  // next full fetch, so the sync marks absent rows isActive=false instead.
  isActive               Boolean            @default(true)
  quantityOnHand         Decimal?           @db.Decimal(12, 4)
  ignoredAt              DateTime?
  lastExternalUpdatedAt  DateTime?
  lastSyncedAt           DateTime
  rawProviderData        Json
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  distributor Organisation                       @relation(fields: [distributorId], references: [id])
  connection  AccountingConnection               @relation(fields: [accountingConnectionId], references: [id])
  // One-to-many, not one-to-one: unlinking soft-deletes (unlinkedAt) rather
  // than hard-deleting, so a product can accumulate historical mapping rows
  // even though only one is ever active (unlinkedAt IS NULL) at a time.
  mappings    ProductAccountingMapping[]
  suggestions AccountingProductMatchSuggestion[]

  @@unique([accountingConnectionId, externalProductId])
  @@index([distributorId, isSold, isActive])
  @@map("external_accounting_products")
}

// Confirmed link between a Wholo Product and one cached external accounting
// product. Written only by an explicit user action (import/confirm/match) —
// never by the sync/matcher, regardless of match confidence.
model ProductAccountingMapping {
  id                     String                       @id @default(cuid())
  distributorId          String
  accountingConnectionId String
  productId              String
  externalProductId      String
  matchMethod            AccountingProductMatchMethod
  linkedByUserId         String
  linkedAt               DateTime                     @default(now())
  unlinkedAt             DateTime?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt

  distributor     Organisation              @relation(fields: [distributorId], references: [id])
  connection      AccountingConnection      @relation(fields: [accountingConnectionId], references: [id])
  product         Product                   @relation(fields: [productId], references: [id])
  externalProduct ExternalAccountingProduct @relation(fields: [externalProductId], references: [id])

  // Both uniques below are made partial (WHERE "unlinkedAt" IS NULL) by hand
  // in the generated migration — same precedent as
  // CustomerAccountingMapping. An unlink-then-relink of the same pair must
  // not collide with the closed-out row.
  @@unique([accountingConnectionId, productId])
  @@unique([accountingConnectionId, externalProductId])
  @@index([distributorId])
  @@map("product_accounting_mappings")
}

// System-suggested product match awaiting human review. The matcher only ever
// writes here; ProductAccountingMapping rows are created exclusively by an
// explicit confirm/match action, regardless of confidence.
model AccountingProductMatchSuggestion {
  id                     String                       @id @default(cuid())
  distributorId          String
  accountingConnectionId String
  externalProductId      String
  suggestedProductId     String
  confidence             Int
  matchMethod            AccountingProductMatchMethod
  matchReason            String
  status                 AccountingProductMatchStatus @default(SUGGESTED)
  reviewedByUserId       String?
  reviewedAt             DateTime?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt

  distributor      Organisation              @relation(fields: [distributorId], references: [id])
  connection       AccountingConnection      @relation(fields: [accountingConnectionId], references: [id])
  externalProduct  ExternalAccountingProduct @relation(fields: [externalProductId], references: [id])
  suggestedProduct Product                   @relation(fields: [suggestedProductId], references: [id])

  @@index([distributorId, status])
  @@index([externalProductId, status])
  @@map("accounting_product_match_suggestions")
}

model TraderCustomerSettings {
  id                          String               @id @default(cuid())
  tradeRelationshipId         String               @unique
  orderAcceptanceModeOverride OrderAcceptanceMode?
  priceListId                 String?
  deliveryProfileId           String?
  tradeRelationship           TradeRelationship    @relation(fields: [tradeRelationshipId], references: [id])
  priceList                   PriceList?           @relation(fields: [priceListId], references: [id])
  deliveryProfile             DeliveryProfile?     @relation(fields: [deliveryProfileId], references: [id])

  @@map("trader_customer_settings")
}

// ─── Outbox ───────────────────────────────────────────────────────────────────

model OutboxEvent {
  id            String            @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        OutboxEventStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  publishedAt   DateTime?
  failedAt      DateTime?
  retryCount    Int               @default(0)
  errorMessage  String?

  @@index([status, createdAt])
  @@map("outbox_events")
}

// ─── Notifications ────────────────────────────────────────────────────────────
// Notification = something happened; NotificationDelivery = an attempt to tell
// someone via a specific channel. Unique constraints provide business
// idempotency against at-least-once outbox/queue delivery.

model Notification {
  id            String           @id @default(cuid())
  type          NotificationType
  distributorId String
  orderId       String?
  dedupeKey     String           @unique
  payload       Json
  createdAt     DateTime         @default(now())

  order      Order?                 @relation(fields: [orderId], references: [id])
  deliveries NotificationDelivery[]

  @@index([distributorId, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String                     @id @default(cuid())
  notificationId String
  channel        NotificationChannel
  audience       NotificationAudience
  recipient      String
  status         NotificationDeliveryStatus @default(PENDING)
  attemptCount   Int                        @default(0)
  sentAt         DateTime?
  failedAt       DateTime?
  errorMessage   String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id])

  @@unique([notificationId, channel, recipient])
  @@index([status, createdAt])
  @@map("notification_deliveries")
}

// ─── Catalogues ───────────────────────────────────────────────────────────────

model Catalogue {
  id            String              @id @default(cuid())
  distributorId String
  name          String
  description   String?
  deletedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  distributor   Organisation        @relation("DistributorCatalogues", fields: [distributorId], references: [id])
  products      CatalogueProduct[]
  customers     CustomerCatalogue[]

  @@index([distributorId])
  @@map("catalogues")
}

model CatalogueProduct {
  catalogueId String
  productId   String
  createdAt   DateTime  @default(now())
  catalogue   Catalogue @relation(fields: [catalogueId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@id([catalogueId, productId])
  @@map("catalogue_products")
}

model CustomerCatalogue {
  tradeRelationshipId String
  catalogueId         String
  createdAt           DateTime          @default(now())
  tradeRelationship   TradeRelationship @relation(fields: [tradeRelationshipId], references: [id])
  catalogue           Catalogue         @relation(fields: [catalogueId], references: [id])

  @@id([tradeRelationshipId, catalogueId])
  @@map("customer_catalogues")
}

// ─── Price Lists ──────────────────────────────────────────────────────────────

model PriceList {
  id               String                   @id @default(cuid())
  distributorId    String
  name             String
  description      String?
  currency         String                   @default("GBP")
  isDefault        Boolean                  @default(false)
  active           Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  distributor      Organisation             @relation("DistributorPriceLists", fields: [distributorId], references: [id])
  rules            PriceListRule[]
  customerSettings TraderCustomerSettings[]
  basedOnRules     PriceListRule[]          @relation("BasePriceListRules")

  @@index([distributorId, active])
  @@index([distributorId, isDefault])
  @@map("price_lists")
}

model PriceListRule {
  id                 String                          @id @default(cuid())
  distributorId      String
  priceListId        String
  selectorType       PriceListRuleSelectorType
  productId          String?
  productVariantId   String?
  minQuantity        Int                             @default(1)
  valueType          PriceListRuleValueType          @default(FIXED_PRICE)
  unitPrice          Decimal?                        @db.Decimal(10, 2)
  discountPercentage Decimal?                        @db.Decimal(5, 2)
  discountBaseType   PriceListRuleDiscountBaseType?
  basePriceListId    String?
  currency           String                          @default("GBP")
  sortOrder          Int                             @default(0)
  active             Boolean                         @default(true)
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt
  priceList          PriceList                       @relation(fields: [priceListId], references: [id])
  product            Product?                        @relation("ProductPriceListRules", fields: [productId], references: [id])
  basePriceList      PriceList?                      @relation("BasePriceListRules", fields: [basePriceListId], references: [id])

  @@index([priceListId, active])
  @@index([priceListId, selectorType, productId])
  @@index([distributorId])
  @@map("price_list_rules")
}

// ─── Delivery Profiles ───────────────────────────────────────────────────────

model DeliveryProfile {
  id                          String                      @id @default(cuid())
  distributorId               String
  name                        String
  active                      Boolean                     @default(true)
  defaultWeekdays             Int[]                       @default([])
  defaultCutoffTime           String                      @default("17:00")
  defaultCutoffProcessingDays Int                         @default(1)
  speciallyEnabledDates       DateTime[]                  @db.Date
  speciallyDisabledDates      DateTime[]                  @db.Date
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  distributor                 Organisation                @relation("DistributorDeliveryProfiles", fields: [distributorId], references: [id])
  cutoffRules                 DeliveryProfileCutoffRule[]
  customerSettings            TraderCustomerSettings[]

  @@index([distributorId, active])
  @@map("delivery_profiles")
}

model DeliveryProfileCutoffRule {
  id                           String          @id @default(cuid())
  deliveryProfileId            String
  weekday                      Int
  cutoffTime                   String
  processingDaysBeforeDelivery Int
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  deliveryProfile              DeliveryProfile @relation(fields: [deliveryProfileId], references: [id], onDelete: Cascade)

  @@unique([deliveryProfileId, weekday])
  @@map("delivery_profile_cutoff_rules")
}

// ─── Order-as (order on behalf of customer) ──────────────────────────────────

model OrderAsSession {
  id                  String    @id  // crypto.randomBytes(24).toString('base64url')
  adminUserId         String
  tradeRelationshipId String
  customerId          String    // denormalised from tradeRelationship.customerId for fast interceptor access
  distributorId       String    // denormalised from tradeRelationship.distributorId for fast interceptor access
  expiresAt           DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  adminUser         User              @relation("AdminOrderAsSessions", fields: [adminUserId], references: [id])
  tradeRelationship TradeRelationship @relation(fields: [tradeRelationshipId], references: [id], onDelete: Cascade)
  customer          Organisation      @relation("OrderAsCustomer", fields: [customerId], references: [id])
  distributor       Organisation      @relation("OrderAsDistributor", fields: [distributorId], references: [id])
  deliveryTokens    OrderAsDeliveryToken[]

  @@unique([adminUserId, tradeRelationshipId])
  @@map("order_as_sessions")
}

model OrderAsDeliveryToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  sessionId String
  expiresAt DateTime
  usedAt    DateTime?

  session   OrderAsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("order_as_delivery_tokens")
}

// ─── Asset Images ─────────────────────────────────────────────────────────────

model AssetImage {
  id              String   @id
  assetType       String
  entityId        String
  distributorId   String
  variants        Json
  dominantColor   String?
  sourceFilename  String?
  sourceMimeType  String
  sourceSizeBytes Int
  sourceWidth     Int?
  sourceHeight    Int?
  sortOrder       Int      @default(0)
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([assetType, entityId, sortOrder])
  @@index([distributorId])
  @@map("asset_images")
}
