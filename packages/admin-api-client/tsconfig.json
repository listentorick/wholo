{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": { "@wholo/types": ["../types/src"] }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
